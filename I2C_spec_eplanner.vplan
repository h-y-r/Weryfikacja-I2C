		section "SDA and SCL signals" {
			details : "Spec text: SDA and SCL signals ";
			coverage "chk_freeBusIsHigh" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text:  When the bus is free, both lines are
HIGH. The output stages of devices connected to the bus must have an open-drain or
open-collector to perform the wired-AND function.</text>;
				ep_annotref "rf2fec33a12e21ad527522ebc2ff8fc31" {
					ep_ref : "UM10204.pdf/afe2b8f4debc2e9a33e8aaa1f0f20117b";
