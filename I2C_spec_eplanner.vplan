			ep_annotref "rb1fd7566b37c88f570a39c424b0b1d7c" {
				ep_ref : "UM10204.pdf/a350110f656f3405dfcd61cae631e0fe5";
			}
		}
		section "SDA and SCL logic" {
			details : "Spec text:  SDA and SCL logic levels ";
			coverage "chk_low=0" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: the levels of the logical ‘0’ (LOW) ";
				ep_annotref "r12f39e12024fab827919275c9ac1bc6d" {
					ep_ref : "UM10204.pdf/aef5075cdd3d8c57a421ffb09ef8d9966";
				}
			}
			coverage "chk_high=1" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text:  ‘1’ (HIGH)";
				ep_annotref "r4774ac96ad69e7c8d8d4c38d90d1c0f1" {
					ep_ref : "UM10204.pdf/a8b3e29973ec8af7fba85921c6b01c1d8";
				}
			}
			ep_annotref "r482ebf0fde6d3f87c8ebc2f2fb5e68cd" {
				ep_ref : "UM10204.pdf/ac9d2740567c46424cdeef2fde22c5c24";
			}
		}
		section "Data validity" {
			details : "Spec text:  Data validity";
			coverage "chk_dataStableWhenSCLHigh" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: The data on the SDA line must be stable during the HIGH period of the clock. ";
				ep_annotref "rd4ec7c2d7ca19eb2bc0e54b47affc4dd" {
					ep_ref : "UM10204.pdf/abd32cecae2dafade488df36df51effb1";
				}
			}
			coverage "chk_dataChangeWhenSCLLow" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text:  The HIGH
or LOW state of the data line can only change when the clock signal on the SCL line is
LOW (see Figure 4). </text>;
				ep_annotref "r9b6f1a4087e3f0e33f2bddf4869c5e07" {
					ep_ref : "UM10204.pdf/a2f763b9d26e9d60b7177a8f2265b4feb";
				}
			}
			coverage "chk_oneClkPulse=oneBit" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text:  One clock pulse is generated for each data bit transferred. ";
				ep_annotref "r3846d373144fd9b64491695f95328cf8" {
					ep_ref : "UM10204.pdf/af378c2d127154c1a0ce6b764e95ee24b";
				}
			}
			ep_annotref "rf9b084ad6ce33287c77533451e98ef6d" {
				ep_ref : "UM10204.pdf/a14c180a728af22367d959fa43772e306";
			}
		}
		section "START and STOP conditions" {
			details : "Spec text:  START and STOP conditions ";
			coverage "chk_controllerGeneratesStartAndStop" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: START and STOP conditions are always generated by the controller. ";
				ep_annotref "r3eb9610c4d0e819c3f166aae3847594f" {
					ep_ref : "UM10204.pdf/ae21286347dc08aabbf8613f5845b1ecc";
				}
			}
			coverage "chk_startDefiniton" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text:  A HIGH to LOW transition on the SDA line while SCL is HIGH defines a
START condition.</text>;
				ep_annotref "rdc26904dfd6f172e30ca78ddad6a175b" {
					ep_ref : "UM10204.pdf/a14293884777b5d9898874cff78904ef4";
				}
			}
			coverage "chk_stopDefiniton" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text:  A LOW to HIGH transition on the SDA line while SCL is HIGH defines
a STOP condition. </text>;
				ep_annotref "r90ab3f4b364d15ed60f84071d2c4702f" {
					ep_ref : "UM10204.pdf/a53cd6de40672e28fff79f56e25d82792";
				}
			}
			coverage "chk_transactionStartWithStartCondition" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: All transactions begin with a START (S)";
				ep_annotref "r11538e304f62c97fa0902462fd96cd77" {
					ep_ref : "UM10204.pdf/abab692c90bb009df89cd4945f313a04b";
				}
			}
			coverage "chk_transationStopWithStopCondition" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: ) and are terminated by a STOP (P) ";
				ep_annotref "r132543217dcec2717b41eea476ba1516" {
					ep_ref : "UM10204.pdf/a131d8efde6781b1cdd233e383fcc065f";
				}
			}
			ep_annotref "re72c2dd149b636cf0ed31b2c83142061" {
				ep_ref : "UM10204.pdf/adf726a762432f05304d7b4740249f4a9";
			}
		}
		section "Byte format" {
			details : "Spec text: Byte format ";
			coverage "chk_byteIs8Bits" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : "Spec text: Every byte put on the SDA line must be eight bits long. ";
				ep_annotref "re3430181a9978b51d5c286705f2e34c2" {
					ep_ref : "UM10204.pdf/a28c3ed16afd7ea871964376da1c5fb31";
				}
			}
			coverage "chk_ackAfterByte" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text: Each byte must be followed by an Acknowledge
bit. </text>;
				ep_annotref "r19839502109c17f12ac34214ae865368" {
					ep_ref : "UM10204.pdf/a815e7be34a7957c9b752786801cbc0db";
				}
			}
			coverage "tst_dataTransferFromMSB" {
				is_check : "TRUE";
				ep_CovChkTc : "TC";
				item_details : "Spec text: Data is transferred with the Most Significant Bit (MSB) f";
				ep_annotref "r144af8150df247a91bf9292c001372e2" {
					ep_ref : "UM10204.pdf/ae2a7bda07fe49260e7ee2b3a0f195c33";
				}
			}
			coverage "tst_waitState" {
				is_check : "TRUE";
				ep_CovChkTc : "TC";
				item_details : <text>Spec text: If a target
cannot receive or transmit another complete byte of data until it has performed some
other function, for example servicing an internal interrupt, it can hold the clock line SCL
LOW to force the controller into a wait state. Data transfer then continues when the target
is ready for another byte of data and releases clock line SCL. </text>;
				ep_annotref "r3b1ba3f5843e9b3c65274aa3080d1d6a" {
					ep_ref : "UM10204.pdf/ad5fc8db428972aa1878b358a717bf0c9";
				}
			}
			ep_annotref "r24ef2363397fe69c96218d81f85cb0ad" {
				ep_ref : "UM10204.pdf/afaa08512e521410f9ebf177c906d79dd";
			}
		}
		section "Acknowledge (ACK) and Not Acknowledge (NACK)" {
			details : "Spec text:  Acknowledge (ACK) and Not Acknowledge (NACK) ";
			coverage "chk_ackAfterByte" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text: The acknowledge takes place after every byte. The acknowledge bit allows the receiver
to signal the transmitter that the byte was successfully received and another byte may
be sent.</text>;
				ep_annotref "r57e26b3fa00db87a39c8f6b77948bad4" {
					ep_ref : "UM10204.pdf/a3ea96cc8417bfdba6d6e4b32770587f1";
				}
			}
			coverage "tst_controllerGeneratesCLKonACK" {
				is_check : "TRUE";
				ep_CovChkTc : "TC";
				item_details : <text>Spec text:  The controller generates all clock pulses, including the acknowledge ninth clock
pulse. </text>;
				ep_annotref "rf08215b8f9b34c158ef419c2a2fb3c0e" {
					ep_ref : "UM10204.pdf/acd7b6ddb95bb138682de5bff6a081a63";
				}
			}
			coverage "chk_ACKDefinition" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text: The Acknowledge signal is defined as follows: the transmitter releases the SDA line
during the acknowledge clock pulse so the receiver can pull the SDA line LOW and it
remains stable LOW during the HIGH period of this clock pulse (see Figure 4). Set-up
and hold times (specified in Section 6) must also be taken into account. </text>;
				ep_annotref "r14457c3b24d8e484d52755b7b8fe6a31" {
					ep_ref : "UM10204.pdf/adec197332915ebead7124afa60ef3c14";
				}
			}
			coverage "chk_NACKDefinition" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text: When SDA remains HIGH during this ninth clock pulse, this is defined as the Not
Acknowledge signal. The controller can then generate either a STOP condition to abort
the transfer, or a repeated START condition to start a new transfer.</text>;
				ep_annotref "r5387d47979d13e556e7883b0d9c426ca" {
					ep_ref : "UM10204.pdf/ac4531e609f4185ec3749f5372377a97e";
				}
			}
			coverage "cov_conditionsForNACK'" {
				ep_CovChkTc : "COV";
				item_details : <text>Spec text:  There are five
conditions that lead to the generation of a NACK:
1. No receiver is present on the bus with the transmitted address so there is no device to
respond with an acknowledge.
2. The receiver is unable to receive or transmit because it is performing some real-time
function and is not ready to start communication with the controller.
3. During the transfer, the receiver gets data or commands that it does not understand.
4. During the transfer, the receiver cannot receive any more data bytes.
5. A controller-receiver must signal the end of the transfer to the target transmitter. </text>;
				ep_annotref "r120a2f3200131601a549a2f9f1fd36a6" {
					ep_ref : "UM10204.pdf/a7e83904e4101398e5d6391306921c8d5";
				}
			}
			ep_annotref "r2038da2f7961e36864ee1b003367a075" {
				ep_ref : "UM10204.pdf/aa07c242bee4173b1591c573204dc0007";
			}
		}
		section "Clock synchronization" {
			details : "Spec text:  Clock synchronization ";
			coverage "chk_clkSynchWhenTwoControllersTransmitting" {
				is_check : "TRUE";
				ep_CovChkTc : "CHK";
				item_details : <text>Spec text: Two controllers can begin transmitting on a free bus at the same time and there must
be a method for deciding which takes control of the bus and complete its transmission.
This is done by clock synchronization and arbitration. In single controller systems, clock
synchronization and arbitration are not needed. </text>;
				ep_annotref "rd304a0b46df6744a1bbc5e0cc2b00f28" {
					ep_ref : "UM10204.pdf/a58ea47b40cfdbd53d6124e3097cd3238";
				}
			}
			coverage "tst_clkSynchDefiniton" {
				is_check : "TRUE";
				ep_CovChkTc : "TC";
				item_details : <text>Spec text: Clock synchronization is performed using the wired-AND connection of
I2C
interfaces
to the SCL line. This means that a HIGH to LOW transition on the SCL line causes the
controllers concerned to start counting off their LOW period and, once a controller clock
has gone LOW, it holds the SCL line in that state until the clock HIGH state is reached
(see Figure 7). However, if another clock is still within its LOW period, the LOW to HIGH
transition of this clock may not change the state of the SCL line. The SCL line is therefore
held LOW by the controller with the longest LOW period. Controllers with shorter LOW
periods enter a HIGH wait-state during this time.
